{
  "mcpServers": {
    "willow": {
      "command": "${HOME}/github/willow-1.7/willow.sh",
      "env": {
        "WILLOW_STORE_ROOT": "${HOME}/.willow/store",
        "WILLOW_PG_DB": "willow",
        "WILLOW_PG_USER": "${USER}",
        "WILLOW_HANDOFF_DB": "${HOME}/Ashokoa/agents/hanuman/index/haumana_handoffs/handoffs.db"
      }
    },
    "law-gazelle": {
      "command": "python3",
      "args": ["${HOME}/github/safe-app-store/apps/law-gazelle/gazelle_mcp.py"]
    },
    "courtlistener": {
      "command": "python3",
      "args": ["${HOME}/github/courtlistener-mcp/src/server.py"]
    }
  }
}
