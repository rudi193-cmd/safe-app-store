# Optional Willow checkout (jeles_sources + llm_edge).
# If unset, Ask Jeles looks for a sibling checkout or ~/github/willow-2.0.
# Linux/macOS example:
# WILLOW_ROOT=$HOME/github/willow-2.0
# Windows PowerShell example:
# WILLOW_ROOT=$env:USERPROFILE\github\willow-2.0
WILLOW_ROOT=

# Willow server URL for batch entity verification (needs verify-feed API)
WILLOW_URL=http://localhost:8420

# LLM synthesis (Ollama → Gemini → Groq via willow inference_router)
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Gemini API key (required for Cloudflare Pages function)
# GEMINI_API_KEY= (same as above)

# Groq API key (optional fallback for Cloudflare Pages function)
# GROQ_API_KEY= (same as above)
