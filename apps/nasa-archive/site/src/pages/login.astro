---
import Base from '../layouts/Base.astro';
---
<Base title="Sign In — NASA Archive">
  <div class="max-w-sm mx-auto py-16">
    <h1 class="text-2xl font-bold text-[#CC4444] uppercase tracking-widest mb-2">Sign In</h1>
    <p class="text-[#666] text-sm mb-8">
      Sign in to claim photos, add stories, and track your rally history.
    </p>

    <!-- Google OAuth -->
    <button id="google-login"
      class="w-full border border-[#CC4444] text-[#CC4444] px-4 py-3 text-sm uppercase tracking-wider hover:bg-[#CC4444] hover:text-white transition-colors flex items-center justify-center gap-3 mb-3">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    </button>

    <!-- GitHub OAuth -->
    <button id="github-login"
      class="w-full border border-[#333] text-[#666] px-4 py-3 text-sm uppercase tracking-wider hover:border-[#CC4444] hover:text-[#CC4444] transition-colors flex items-center justify-center gap-3 mb-4">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      Continue with GitHub
    </button>

    <!-- Divider -->
    <div class="flex items-center gap-3 mb-4">
      <div class="flex-1 border-t border-[#333]"></div>
      <span class="text-[#444] text-xs uppercase tracking-wider">or</span>
      <div class="flex-1 border-t border-[#333]"></div>
    </div>

    <!-- Email magic link -->
    <form id="email-form">
      <input
        type="email"
        id="email-input"
        placeholder="your@email.com"
        class="w-full bg-transparent border border-[#333] px-4 py-3 text-sm text-[#f5f0e8] placeholder-[#444] focus:outline-none focus:border-[#CC4444] mb-3"
        required
      />
      <button type="submit"
        class="w-full border border-[#555] text-[#666] px-4 py-3 text-sm uppercase tracking-wider hover:border-[#CC4444] hover:text-[#CC4444] transition-colors">
        Send Magic Link
      </button>
    </form>

    <div id="auth-message" class="mt-4 text-sm text-center hidden"></div>

    <p class="text-[#444] text-xs text-center mt-8">
      Your account lets you claim photos, add stories, and track the rallies you've been to.
      Nothing is sold, nothing is shared.
    </p>
  </div>
</Base>

<script>
  import { signInWithGoogle, signInWithGitHub, signInWithEmail } from '../lib/auth';

  const message = document.getElementById('auth-message')!;

  function showMessage(text: string, isError = false) {
    message.textContent = text;
    message.className = `mt-4 text-sm text-center ${isError ? 'text-[#CC4444]' : 'text-[#888]'}`;
    message.classList.remove('hidden');
  }

  // Google OAuth
  document.getElementById('google-login')!.addEventListener('click', async () => {
    const { error } = await signInWithGoogle();
    if (error) showMessage(error.message, true);
  });

  // GitHub OAuth
  document.getElementById('github-login')!.addEventListener('click', async () => {
    const { error } = await signInWithGitHub();
    if (error) showMessage(error.message, true);
  });

  // Email magic link
  document.getElementById('email-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email-input') as HTMLInputElement).value;
    const { error } = await signInWithEmail(email);
    if (error) {
      console.error('Magic link error:', error);
      showMessage(error.message, true);
    } else {
      showMessage(`Magic link sent to ${email} — check your inbox.`);
    }
  });
</script>
