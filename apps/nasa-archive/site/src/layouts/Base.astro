---
import '../styles/global.css';
import SafeConsentBanner from '../components/SafeConsentBanner.astro';
const { title = 'NASA — North America Scootering Archive' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <SafeConsentBanner />

    <!-- Header -->
    <header>
      <!-- Eyebrow bar -->
      <div style="background:var(--surface); border-bottom:1px solid var(--border); padding:0.35rem 1.5rem;"
           class="flex items-center justify-between">
        <span style="font-size:0.6rem; letter-spacing:0.2em; color:var(--dim); text-transform:uppercase;">
          archive · est. 1997 · north america
        </span>
        <span class="flex items-center gap-4" style="font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase;">
          <a href="/archives" style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Knowledge Base</a>
          <span style="color:var(--dim);">|</span>
          <a href="/login" id="nav-signin" style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Sign In</a>
          <span id="nav-user" class="hidden items-center gap-3">
            <a href="/profile" id="nav-username" style="color:var(--cream); font-size:0.6rem;" class="hover:text-[#CC4444] transition-colors"></a>
            <button id="nav-signout" style="color:var(--dim); font-size:0.6rem; letter-spacing:0.15em; background:none; border:none; cursor:pointer; text-transform:uppercase; font-family:var(--font-mono);" class="hover:text-[#CC4444] transition-colors">Out</button>
          </span>
        </span>
      </div>

      <!-- Main header -->
      <div style="border-bottom:2px solid var(--red);">
        <div class="max-w-7xl mx-auto px-6 flex items-center justify-between" style="padding-top:0.75rem; padding-bottom:0.75rem;">
          <a href="/" class="flex items-baseline gap-3">
            <span class="nasa-mark">NASA</span>
            <span style="font-size:0.62rem; letter-spacing:0.12em; color:var(--muted); text-transform:uppercase; line-height:1.3; max-width:140px;">
              North America<br>Scootering Archive
            </span>
          </a>
          <nav class="flex items-center gap-6" style="font-size:0.68rem; letter-spacing:0.15em; text-transform:uppercase;">
            <a href="/rallies"    style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Rallies</a>
            <a href="/patches"   style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Patches</a>
            <a href="/calendar"  style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Calendar</a>
            <a href="/map"       style="color:var(--muted);" class="hover:text-[#CC4444] transition-colors">Map</a>
            <a href="/contribute" class="btn-outline" style="padding:0.3rem 1rem; font-size:0.6rem;">Contribute</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-7xl mx-auto px-6 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top:1px solid var(--border); margin-top:6rem;">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8" style="font-size:0.68rem; color:var(--muted);">
          <div>
            <div class="nasa-mark" style="font-size:1.4rem; margin-bottom:0.5rem;">NASA</div>
            <p style="line-height:1.8;">North America Scootering Archive.<br>
            The complete record of rally history —<br>before it disappears.</p>
          </div>
          <div>
            <div style="letter-spacing:0.2em; text-transform:uppercase; font-size:0.6rem; color:var(--red); margin-bottom:0.75rem;">Archive</div>
            <div class="flex flex-col gap-2">
              <a href="/rallies"  class="hover:text-[#CC4444] transition-colors">Rally History</a>
              <a href="/patches"  class="hover:text-[#CC4444] transition-colors">Patch Gallery</a>
              <a href="/calendar" class="hover:text-[#CC4444] transition-colors">Calendar</a>
              <a href="/map"      class="hover:text-[#CC4444] transition-colors">Rally Map</a>
              <a href="/archives" class="hover:text-[#CC4444] transition-colors">Knowledge Base</a>
            </div>
          </div>
          <div>
            <div style="letter-spacing:0.2em; text-transform:uppercase; font-size:0.6rem; color:var(--red); margin-bottom:0.75rem;">Contribute</div>
            <div class="flex flex-col gap-2">
              <a href="/contribute" class="hover:text-[#CC4444] transition-colors">Add Photos</a>
              <a href="/contribute" class="hover:text-[#CC4444] transition-colors">Submit a Rally</a>
              <a href="/contribute" class="hover:text-[#CC4444] transition-colors">Patch Submissions</a>
              <a href="https://github.com/rudi193-cmd/nasa-archive" class="hover:text-[#CC4444] transition-colors">GitHub</a>
            </div>
          </div>
        </div>
        <div style="margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border); font-size:0.6rem; letter-spacing:0.1em; color:var(--dim);">
          NASA &#183; North America Scootering Archive &#183; Powered by Willow &#183; SAFE OS
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  import { supabase } from '../lib/supabase';

  const signIn  = document.getElementById('nav-signin');
  const navUser = document.getElementById('nav-user');
  const navName = document.getElementById('nav-username');
  const signOut = document.getElementById('nav-signout');

  async function updateNav() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.user) {
      signIn?.classList.add('hidden');
      navUser?.classList.remove('hidden');
      navUser?.classList.add('inline-flex');
      const name = session.user.user_metadata?.user_name
        || session.user.user_metadata?.name
        || session.user.email?.split('@')[0]
        || 'you';
      if (navName) navName.textContent = name;
    } else {
      signIn?.classList.remove('hidden');
      navUser?.classList.add('hidden');
    }
  }

  updateNav();
  signOut?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/';
  });
  supabase.auth.onAuthStateChange(() => updateNav());
</script>
